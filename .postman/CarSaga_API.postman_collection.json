{
  "info": {
    "name": "CarSaga API",
    "_postman_id": "carsaga-api-collection-v1",
    "description": "Complete CarSaga REST API collection. \n\n**SETUP:**\n1. Run `POST /auth/login` first\n2. Copy the `token` from the response\n3. Go to the **CarSaga Collection → Variables** tab\n4. Paste the token into the `token` variable\n\nAll authenticated routes use `{{token}}` automatically.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "https://car-saga-api.onrender.com/api",
      "type": "string"
    },
    {
      "key": "token",
      "value": "PASTE_YOUR_TOKEN_HERE",
      "type": "string"
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{token}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "🔐 Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test User\",\n  \"email\": \"test@example.com\",\n  \"password\": \"password123\",\n  \"role\": \"buyer\"\n}"
            }
          }
        },
        {
          "name": "Login ⭐ (run first)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.token) {",
                  "  pm.collectionVariables.set('token', res.token);",
                  "  console.log('✅ Token auto-saved to collection variable!');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@example.com\",\n  \"password\": \"password123\"\n}"
            }
          }
        },
        {
          "name": "Google OAuth",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/google",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"credential\": \"<google_id_token_from_frontend>\"\n}"
            }
          }
        },
        {
          "name": "Get My Profile",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/auth/me"
          }
        },
        {
          "name": "Send OTP (for password change)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/send-otp",
            "body": { "mode": "raw", "raw": "" }
          }
        },
        {
          "name": "Update Profile",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/profile",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"New Name\",\n  \"currentPassword\": \"oldpassword\",\n  \"newPassword\": \"newpassword123\",\n  \"otp\": \"482910\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "🚗 Cars",
      "item": [
        {
          "name": "Get My Cars",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/cars"
          }
        },
        {
          "name": "Create Car (+ auto report)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/cars",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"make\": \"Hyundai\",\n  \"model\": \"Creta\",\n  \"year\": 2022,\n  \"vin\": \"MH12AB1234\",\n  \"status\": \"verified\",\n  \"riskLevel\": \"low\",\n  \"location\": \"Mumbai, MH\",\n  \"brandImage\": \"\",\n  \"challanStatus\": {\n    \"totalChallan\": 0,\n    \"statusMessage\": \"No pending challans\"\n  }\n}"
            }
          }
        },
        {
          "name": "Get Car by ID",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/cars/REPLACE_WITH_CAR_ID"
          }
        },
        {
          "name": "Update Car",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/cars/REPLACE_WITH_CAR_ID",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"riskLevel\": \"medium\",\n  \"location\": \"Delhi, DL\"\n}"
            }
          }
        },
        {
          "name": "Delete Car",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/cars/REPLACE_WITH_CAR_ID"
          }
        }
      ]
    },
    {
      "name": "💬 Chat (Saga AI)",
      "item": [
        {
          "name": "Create Chat Session",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/chat",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"reportId\": null\n}"
            }
          }
        },
        {
          "name": "Send Message",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/chat/REPLACE_WITH_CHAT_ID/message",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"text\": \"Is this car worth buying at ₹8 lakh?\"\n}"
            }
          }
        },
        {
          "name": "Get Chat Session",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/chat/REPLACE_WITH_CHAT_ID"
          }
        }
      ]
    },
    {
      "name": "📄 Reports",
      "item": [
        {
          "name": "Get All My Reports",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/reports"
          }
        },
        {
          "name": "Get Report by Car ID",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/reports/car/REPLACE_WITH_CAR_ID"
          }
        },
        {
          "name": "Get Report by Report ID",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/reports/REPLACE_WITH_REPORT_ID"
          }
        },
        {
          "name": "Create Report (manual)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/reports",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"car\": \"REPLACE_WITH_CAR_ID\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "📊 Analytics",
      "item": [
        {
          "name": "Get User Summary",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/analytics/summary"
          }
        },
        {
          "name": "Compare Cars",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/analytics/compare?ids=CAR_ID_1&ids=CAR_ID_2",
              "host": ["{{baseUrl}}"],
              "path": ["analytics", "compare"],
              "query": [
                { "key": "ids", "value": "CAR_ID_1" },
                { "key": "ids", "value": "CAR_ID_2" }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "🔍 Car Database",
      "item": [
        {
          "name": "Get All Brands",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/car-database/brands"
          }
        },
        {
          "name": "Get Models by Brand",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/car-database/models?brand_id=BRAND_ID",
              "query": [{ "key": "brand_id", "value": "BRAND_ID" }]
            }
          }
        },
        {
          "name": "Get Generations by Model",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/car-database/generations?model_id=MODEL_ID",
              "query": [{ "key": "model_id", "value": "MODEL_ID" }]
            }
          }
        },
        {
          "name": "Get Variations by Generation",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/car-database/variations/GENERATION_ID"
          }
        },
        {
          "name": "Check Challans",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/car-database/challan",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"reg_no\": \"MH12AB1234\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "🔧 Mechanics",
      "item": [
        {
          "name": "Get All Mechanics",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "url": "{{baseUrl}}/mechanics"
          }
        },
        {
          "name": "Get Nearby Mechanics",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/mechanics/nearby?lat=19.0760&lng=72.8777&radius=10",
              "query": [
                { "key": "lat", "value": "19.0760" },
                { "key": "lng", "value": "72.8777" },
                { "key": "radius", "value": "10" }
              ]
            }
          }
        },
        {
          "name": "Create Mechanic",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/mechanics",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Raju Auto Works\",\n  \"location\": \"Pune, MH\",\n  \"specialization\": \"Engine & Transmission\",\n  \"contact\": \"+91 98765 43210\"\n}"
            }
          }
        }
      ]
    }
  ]
}
